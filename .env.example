#--------------------------------------------------------------------
# KPI - Variables de Entorno
#--------------------------------------------------------------------
# Copiar este archivo como .env y completar con valores reales.
# NUNCA commitear el archivo .env con credenciales.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENTORNO
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
# CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APLICACION
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'

#--------------------------------------------------------------------
# BASE DE DATOS PRINCIPAL
#--------------------------------------------------------------------
database.default.hostname = 127.0.0.1
database.default.database = kpicycloid
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SENDGRID (Email transaccional)
#--------------------------------------------------------------------
SENDGRID_API_KEY =

#--------------------------------------------------------------------
# OPENAI (Generacion de indicadores y actividades)
#--------------------------------------------------------------------
OPENAI_API_KEY =
OPENAI_MODEL = gpt-3.5-turbo

#--------------------------------------------------------------------
# BITACORA - Configuracion
#--------------------------------------------------------------------
# Destinatarios del reporte diario (separados por coma)
BITACORA_REPORT_EMAILS =

# Fecha de inicio de primera quincena (formato YYYY-MM-DD)
BITACORA_PRIMERA_QUINCENA =

# Email del admin que recibe solicitudes de correccion
BITACORA_ADMIN_CORRECCIONES =

#--------------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (VAPID keys)
#--------------------------------------------------------------------
# Generar con: ./vendor/bin/minishlink-web-push generate-keys
VAPID_PUBLIC_KEY =
VAPID_PRIVATE_KEY =

#--------------------------------------------------------------------
# SESIONES
#--------------------------------------------------------------------
# session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
# session.savePath = ci_sessions
